# 9router or any OpenAI-compatible /v1 endpoint.
# NapMem-VN also auto-detects compatible .env files from sibling repos such as
# Agent-as-a-Router and System-III-Router.
NINEROUTER_BASE_URL=https://your-9router-host/v1
NINEROUTER_API_KEY=sk-...
NAPMEM_MODEL=gpt-5.5

# Optional only when local Python lacks the CA issuer for your dev endpoint.
# Prefer fixing certs; use this for local smoke runs.
# NAPMEM_INSECURE_SSL=1
